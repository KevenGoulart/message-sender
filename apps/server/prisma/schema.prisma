generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  createdAt       DateTime          @default(now())
  receiversGroups ReceiversGroups[]
  groups          Group[]
  templates       Template[]
  emailHistories  EmailHistory[]
  receivers       Receiver[]
}

model EmailHistory {
  id      String @id @default(uuid())
  sentTo  String
  subject String
  body    String
  userId  String
  user    User   @relation(fields: [userId], references: [id])
}

model Group {
  id        String            @id @default(uuid())
  name      String
  createdAt DateTime          @default(now())
  receiver  ReceiversGroups[]
  userId    String?
  user      User?             @relation(fields: [userId], references: [id])
}

model Receiver {
  id     String            @id @default(uuid())
  email  String            @unique
  name   String
  groups ReceiversGroups[]
  userId String?
  user   User?             @relation(fields: [userId], references: [id])
}

model ReceiversGroups {
  groupId    String
  receiverId String
  userId     String
  group      Group     @relation(fields: [groupId], references: [id])
  receiver   Receiver? @relation(fields: [receiverId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@id([groupId, receiverId])
}

model Template {
  id        String   @id @default(uuid())
  name      String
  content   String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
